PORT=3000
JWT_SECRET=change-me-in-production

# PostgreSQL (Neon) — recomendado en Render. Los datos de jugadores persisten entre redeploys.
# DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# SQLite local — solo si NO defines DATABASE_URL (desarrollo sin Neon).
# DB_PATH=data/arrowmaze.db

# Al arrancar (`npm run dev`) se siembran los JSON de `levels/` y se vigilan cambios en caliente.
