  "include": ["src", "docs/contract", "tests"],
  "exclude": ["node_modules", "dist"]
}
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["jest", "node"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
